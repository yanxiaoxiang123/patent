# ===================
# 必填配置（必须设置）
# ===================

# 安全密钥（用于 JWT token 签名）
TOKEN_SECRET=your-secure-secret-key-here

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=iprs

# Redis（用于速率限制）
REDIS_HOST=localhost
REDIS_PORT=6379

# ===================
# 可选配置（有默认值）
# ===================

# Ollama AI 服务
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Redis 扩展配置
REDIS_DB=0
REDIS_URL=

# 开发选项
DEBUG=false

# CORS（JSON 数组格式）
CORS_ORIGINS=["http://localhost:5173"]

# 速率限制
RATE_LIMIT_MAX=100
RATE_LIMIT_LOGIN_MAX=5

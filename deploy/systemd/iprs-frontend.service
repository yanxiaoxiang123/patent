[Unit]
Description=IPRS Frontend (Vite Dev Server)
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/patent_zgn/patent/frontend
Environment=NODE_ENV=development
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0 --port 5173
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target


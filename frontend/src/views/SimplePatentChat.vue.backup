<template>
  <div class="patent-chat">
    <!-- 侧边栏切换按钮 -->
    <div v-if="!showSidebar" class="sidebar-toggle">
      <el-tooltip content="显示聊天记录" placement="right">
        <el-button
          type="default"
          size="small"
          circle
          @click="showSidebar = true"
        >
          <el-icon><Files /></el-icon>
        </el-button>
      </el-tooltip>
    </div>

    <div class="chat-layout">
      <!-- 聊天记录侧边栏 -->
      <div v-show="showSidebar" class="session-sidebar ax-menu">
        <div class="sidebar-header">
          <div class="sidebar-actions">
            <div class="sidebar-title">聊天记录</div>
            <Button
              type="text"
              size="small"
              class="sidebar-close-btn"
              @click="showSidebar = false"
            >
              <template #icon>
                <CloseOutlined />
              </template>
            </Button>
          </div>
        </div>

        <Button
          type="link"
          class="sidebar-add-btn"
          @click="createNewSessionAndHideSidebar"
        >
          <template #icon>
            <PlusOutlined />
          </template>
          新建会话
        </Button>

        <Conversations
          v-if="conversationsItems.length > 0"
          class="ax-conversations"
          :items="conversationsItems"
          :active-key="activeConversationKey"
          :menu="conversationMenu"
          @active-change="onConversationActiveChange"
        />

        <div v-else class="empty-sessions">
          <el-icon size="32" color="#d1d5db"><Files /></el-icon>
          <p>暂无聊天记录</p>
        </div>
      </div>

      <!-- 主聊天区域 -->
      <div class="chat-main-area">
        <div class="chat-top-bar">
          <div class="chat-brand">
            <img class="chat-logo-dot" src="/0.png" alt="" />
            <div class="chat-brand-text">
              <div class="chat-brand-title">专利 AI 助手</div>
            </div>
          </div>
          <div class="chat-actions">
            <el-button
              v-if="isAdmin"
              type="default"
              size="small"
              @click="$router.push('/admin/users')"
            >
              用户管理
            </el-button>
          </div>
        </div>
        <div class="chat-main">
          <div class="ax-chat">
            <Bubble.List
              ref="bubbleListRef"
              :items="bubbleItems"
              :roles="bubbleRoles"
              :auto-scroll="true"
              class="ax-messages"
            >
              <template #message="{ item }">
                <div
                  v-if="item.__type === 'placeholder'"
                  class="ax-placeholder"
                >
                  <Welcome
                    variant="borderless"
                    title="今天有什么可以帮到你？"
                    description="上传专利文档或直接提问，我会给出结构化建议。"
                  />
                  <Prompts
                    title="模板示例"
                    wrap
                    class="ax-prompts ax-prompts-placeholder"
                    :items="placeholderPromptsItems"
                    :styles="placeholderPromptsStyles"
                    @item-click="onPromptsItemClick"
                  />
                </div>

                <div v-else class="ax-message-body">
                  <template v-if="item.__isStreaming">
                    <div class="message-text streaming">
                      <div class="streaming-content">
                        <template
                          v-if="
                            splitThinking(currentResponse, {
                              allowPartial: true,
                            }).thinking
                          "
                        >
                          <div
                            class="thinking-toggle"
                            @click="toggleStreamingThinking"
                          >
                            <DownOutlined
                              :class="[
                                'thinking-toggle-icon',
                                { expanded: streamingThinkingExpanded },
                              ]"
                            />
                            <span class="thinking-toggle-text">
                              {{
                                streamingThinkingExpanded
                                  ? "隐藏思考过程"
                                  : "查看思考过程"
                              }}
                            </span>
                          </div>
                          <div
                            v-if="streamingThinkingExpanded"
                            class="thinking-content"
                          >
                            <MarkdownRender
                              custom-id="streaming-thinking"
                              :content="
                                splitThinking(currentResponse, {
                                  allowPartial: true,
                                }).thinking
                              "
                            />
                          </div>
                          <div
                            v-if="
                              splitThinking(currentResponse, {
                                allowPartial: true,
                              }).answer
                            "
                            class="final-answer"
                          >
                            <MarkdownRender
                              custom-id="streaming-answer"
                              :content="
                                splitThinking(currentResponse, {
                                  allowPartial: true,
                                }).answer
                              "
                            />
                          </div>
                        </template>
                        <template v-else>
                          <MarkdownRender
                            custom-id="streaming"
                            :content="currentResponse"
                          />
                        </template>
                      </div>
                      <span class="typing-cursor">|</span>
                    </div>
                  </template>

                  <template v-else-if="item.role === 'ai'">
                    <div class="message-text">
                      <template v-if="splitThinking(item.content).thinking">
                        <div
                          class="thinking-toggle"
                          @click="toggleThinking(item.__index)"
                        >
                          <DownOutlined
                            :class="[
                              'thinking-toggle-icon',
                              { expanded: isThinkingVisible(item.__index) },
                            ]"
                          />
                          <span class="thinking-toggle-text">
                            {{
                              isThinkingVisible(item.__index)
                                ? "隐藏思考过程"
                                : "查看思考过程"
                            }}
                          </span>
                        </div>
                        <div
                          v-if="isThinkingVisible(item.__index)"
                          class="thinking-content"
                        >
                          <MarkdownRender
                            :custom-id="`thinking-${item.__index}`"
                            :content="splitThinking(item.content).thinking"
                          />
                        </div>
                        <div class="final-answer">
                          <MarkdownRender
                            :custom-id="`answer-${item.__index}`"
                            :content="splitThinking(item.content).answer"
                          />
                        </div>
                      </template>
                      <template v-else>
                        <MarkdownRender
                          :custom-id="`ai-${item.__index}`"
                          :content="item.content"
                        />
                      </template>
                    </div>
                    <div
                      v-if="item.__type !== 'placeholder'"
                      class="ax-bubble-footer"
                    >
                      <Button
                        type="text"
                        size="small"
                        @click="copyMessage(item.content)"
                        >复制</Button
                      >
                      <Button
                        type="text"
                        size="small"
                        @click="regenerateResponse(item.__index)"
                        >重新生成</Button
                      >
                    </div>
                  </template>

                  <template v-else>
                    <div class="message-text">
                      <MarkdownRender
                        :custom-id="`user-${item.__index}`"
                        :content="item.content"
                      />
                    </div>
                    <div
                      v-if="item.__raw && item.__raw.attachments"
                      class="message-attachments"
                    >
                      <div
                        v-for="file in item.__raw.attachments"
                        :key="file.id"
                        class="attachment-item"
                      >
                        <span>{{ file.name }}</span>
                        <el-tag
                          size="small"
                          :type="
                            file.error
                              ? 'danger'
                              : file.parsed
                                ? 'success'
                                : 'warning'
                          "
                        >
                          {{
                            file.error
                              ? "解析失败"
                              : file.parsed
                                ? "已解析"
                                : "解析中"
                          }}
                        </el-tag>
                        <el-button
                          v-if="
                            file.parsed &&
                            (file.parsedContent || file.parsed_content)
                          "
                          type="text"
                          size="small"
                          @click="openFilePreview(file)"
                        >
                          预览
                        </el-button>
                      </div>
                    </div>
                  </template>
                </div>
              </template>
            </Bubble.List>

            <Sender
              :value="inputMessage"
              :loading="isLoading"
              :disabled="isLoading"
              :actions="renderSenderActions"
              class="ax-sender"
              @submit="onSenderSubmit"
              @change="onSenderChange"
            >
              <template #prefix>
                <Badge :dot="uploadedFiles.length > 0 && !attachmentsOpen">
                  <Button
                    type="text"
                    @click="attachmentsOpen = !attachmentsOpen"
                  >
                    <template #icon>
                      <PaperClipOutlined />
                    </template>
                  </Button>
                </Badge>
              </template>

              <template #header>
                <Sender.Header
                  title="附件"
                  :open="attachmentsOpen"
                  :styles="{ content: { padding: 0 } }"
                  @open-change="(open) => (attachmentsOpen = open)"
                >
                  <Attachments
                    :before-upload="beforeAntdUpload"
                    :custom-request="handleAttachmentCustomRequest"
                    :items="attachmentItems"
                    accept=".doc,.docx,.pdf"
                    :multiple="true"
                    :on-remove="handleAttachmentRemove"
                    @change="handleAttachmentsChange"
                  >
                    <template #placeholder="type">
                      <Flex
                        v-if="type && type.type === 'inline'"
                        align="center"
                        justify="center"
                        vertical
                        gap="2"
                        class="ax-attachments-inline"
                      >
                        <Typography.Text
                          style="font-size: 30px; line-height: 1"
                        >
                          <CloudUploadOutlined />
                        </Typography.Text>
                        <Typography.Title
                          :level="5"
                          style="margin: 0; font-size: 14px; line-height: 1.5"
                        >
                          上传文档
                        </Typography.Title>
                        <Typography.Text type="secondary">
                          点击或拖拽文件到此处上传（.doc/.docx/.pdf，≤20MB）
                        </Typography.Text>
                      </Flex>
                      <Typography.Text v-if="type && type.type === 'drop'">
                        松开即可上传
                      </Typography.Text>
                    </template>
                  </Attachments>
                </Sender.Header>
              </template>
            </Sender>
          </div>
        </div>

        <div class="page-disclaimer">内容由 AI 生成，请仔细甄别</div>

        <!-- 设置对话框（仅选择模型） -->
        <el-dialog v-model="showSettings" title="设置" width="400px">
          <el-form :model="settings" label-width="100px">
            <el-form-item label="AI 模型">
              <el-select v-model="settings.model">
                <el-option label="Qwen3-8b (快速)" value="qwen3:8b" />
                <el-option label="Qwen3-72b (专业)" value="qwen3:72b" />
              </el-select>
            </el-form-item>
          </el-form>
          <template #footer>
            <el-button @click="showSettings = false">关闭</el-button>
          </template>
        </el-dialog>

        <el-dialog
          v-model="previewDialogVisible"
          :title="previewTitle"
          width="600px"
        >
          <div class="preview-content">
            <pre>{{ previewContent }}</pre>
          </div>
          <template #footer>
            <el-button @click="previewDialogVisible = false">关闭</el-button>
          </template>
        </el-dialog>
      </div>
    </div>
  </div>
</template>

<script setup>
import {
  ref,
  reactive,
  h,
  nextTick,
  watch,
  onMounted,
  onUnmounted,
  computed,
} from "vue";
import { ElMessage } from "element-plus";
import { Files } from "@element-plus/icons-vue";
import { Badge, Button, Flex, Typography } from "ant-design-vue";
import {
  CloudUploadOutlined,
  CloseOutlined,
  DownOutlined,
  PaperClipOutlined,
  PlusOutlined,
} from "@ant-design/icons-vue";
import {
  Attachments,
  Bubble,
  Conversations,
  Prompts,
  Sender,
  Welcome,
} from "ant-design-x-vue";
import { uploadDocument, parseDocument } from "@/services/documents";
import api from "@/services/api";
import MarkdownRender from "markstream-vue";
import { useAuthStore } from "@/stores/auth";
import {
  buildPatentSystemPrompt,
  buildIPCSystemPrompt,
  buildGeneralCaseAuditSystemPrompt,
  buildProjectCaseAuditSystemPrompt,
  buildAuditSystemPrompt,
} from "@/utils/patentPrompts";

const UPLOADED_FILES_STORAGE_KEY = "patent_uploaded_files";

const chatSessions = ref([]);
const currentSessionId = ref(null);
const showSidebar = ref(false);

const messages = ref([]);
const inputMessage = ref("");
const isLoading = ref(false);
const currentResponse = ref("");
const currentThinking = ref("");
const currentAnswer = ref("");
const currentController = ref(null);
const currentReader = ref(null);
const attachmentsOpen = ref(false);
const showSettings = ref(false);
const uploadedFiles = ref([]);
const previewDialogVisible = ref(false);
const previewTitle = ref("");
const previewContent = ref("");
const currentTemplateId = ref(null);

const bubbleListRef = ref(null);
const attachmentItems = ref([]);
const thinkingExpanded = ref({});
const streamingThinkingExpanded = ref(true);
const currentBackendSessionId = ref(null);
const authStore = useAuthStore();
authStore.initUser();
const isAdmin = computed(() => authStore.isAdmin);

const hasThinkingStructure = (content) => {
  if (!content || typeof content !== "string") return false;
  const thinkingLabels = [
    "思考过程（简要分析）：",
    "思考过程（简要分析）:",
    "思考过程：",
    "思考过程:",
  ];
  const answerLabels = ["最终回答：", "最终回答:"];
  const hasThinking = thinkingLabels.some((label) => content.includes(label));
  const hasAnswer = answerLabels.some((label) => content.includes(label));
  return hasThinking && hasAnswer;
};

const ensureThinkingStructure = (content, options = {}) => {
  if (!content || typeof content !== "string") return content || "";
  if (hasThinkingStructure(content)) return content;
  return content;
};

// 专利模板
const patentTemplates = ref([
  {
    id: 1,
    title: "普通案例审核",
    icon: "Document",
    description: "对上传的普通案例进行审核并给出建议",
    prompt: "",
  },
  {
    id: 3,
    title: "专案案例审核",
    icon: "EditPen",
    description: "对上传的专案案例进行审核并输出报告",
    prompt: "",
  },
  {
    id: 2,
    title: "专利审核指导",
    icon: "EditPen",
    description: "学习专利申请文件的审核技巧",
    prompt: "根据我刚刚上传的文件，帮我进行专利审核",
  },
  {
    id: 5,
    title: "IPC 分类指导",
    icon: "Shield",
    description: "根据技术方案选择合适的专利 IPC 分类号",
    prompt:
      "我有一个专利申请书，请帮我分析应该归入哪些 IPC 分类号，并说明每个分类号的含义和选择理由。",
  },
]);

// 固定模型配置
const settings = reactive({
  model: "qwen3:8b",
});

// 监听消息变化，自动滚动到底部
watch(
  messages,
  () => {
    nextTick(() => {
      scrollToBottom();
    });
  },
  { deep: true },
);

// 监听流式响应内容变化，持续滚动到底部
watch(currentResponse, () => {
  nextTick(() => {
    scrollToBottom();
  });
});

watch(
  uploadedFiles,
  (list) => {
    try {
      const plain = list.map((file) => ({
        id: file.id,
        name: file.name,
        type: file.type,
        parsed: !!file.parsed,
        parsedContent: file.parsedContent || file.parsed_content || null,
        error: !!file.error,
        parsingThinkingSteps: file.parsingThinkingSteps || [],
      }));
      localStorage.setItem(UPLOADED_FILES_STORAGE_KEY, JSON.stringify(plain));
    } catch (e) {
      console.error("保存上传文件状态失败:", e);
    }
  },
  { deep: true },
);

const sendTemplate = async (template) => {
  currentTemplateId.value = Number(template.id);
  if (Number(template.id) === 1) {
    inputMessage.value = "";
  } else if (Number(template.id) === 3) {
    inputMessage.value = "";
  } else {
    inputMessage.value = template.prompt;
  }
  await sendMessage();
};

const primaryTemplates = computed(() => {
  const list = Array.isArray(patentTemplates.value)
    ? patentTemplates.value
    : [];
  return list.slice(0, 3);
});

const secondaryTemplates = computed(() => {
  const list = Array.isArray(patentTemplates.value)
    ? patentTemplates.value
    : [];
  return list.slice(3);
});

const bubbleRoles = {
  ai: {
    placement: "start",
    typing: { step: 5, interval: 20 },
    styles: {
      content: {
        width: "calc(100% - 40px)",
        maxWidth: "720px",
        marginLeft: "auto",
        marginRight: "auto",
        padding: "18px 20px",
        borderRadius: "18px 18px 18px 4px",
        background: "rgba(255, 255, 255, 0.98)",
        border: "1px solid rgba(148, 163, 184, 0.3)",
        boxShadow: "0 18px 40px rgba(15, 23, 42, 0.12)",
        backdropFilter: "blur(22px)",
        boxSizing: "border-box",
      },
    },
    variant: "filled",
  },
  local: {
    placement: "end",
    variant: "shadow",
    styles: {
      content: {
        maxWidth: "720px",
        padding: "16px 20px",
        borderRadius: "18px 18px 4px 18px",
        background: "#111827",
        color: "#f9fafb",
        boxShadow: "0 18px 40px rgba(15, 23, 42, 0.5)",
      },
    },
  },
};

const bubbleItems = computed(() => {
  if (messages.value.length === 0 && !isLoading.value) {
    return [
      {
        key: "placeholder",
        role: "ai",
        variant: "borderless",
        rootClassName: "ax-bubble-placeholder",
        __type: "placeholder",
      },
    ];
  }

  const items = messages.value.map((message, index) => ({
    key: `${index}-${message.timestamp ? Number(new Date(message.timestamp)) : index}`,
    role: message.role === "user" ? "local" : "ai",
    content: message.content,
    __raw: message,
    __index: index,
  }));

  if (isLoading.value) {
    items.push({
      key: `streaming-${items.length}`,
      role: "ai",
      content: currentResponse.value,
      loading: !currentResponse.value,
      __isStreaming: true,
    });
  }

  return items;
});

const placeholderPromptsItems = computed(() => {
  return [...primaryTemplates.value, ...secondaryTemplates.value].map((t) => ({
    key: String(t.id),
    label: t.title,
    description: t.description || "",
  }));
});

const placeholderPromptsStyles = {
  list: {
    width: "100%",
  },
  item: {
    flex: 1,
  },
};

const conversationsItems = computed(() => {
  const list = Array.isArray(chatSessions.value) ? chatSessions.value : [];
  return list.map((session) => {
    const time = session.updatedAt || session.createdAt || Date.now();
    const count =
      typeof session.messageCount === "number"
        ? session.messageCount
        : Array.isArray(session.messages)
          ? session.messages.length
          : 0;

    return {
      key: String(session.id),
      timestamp: typeof time === "number" ? time : undefined,
      label: session.title || "新对话",
    };
  });
});

const activeConversationKey = computed(() => {
  if (currentSessionId.value === null || currentSessionId.value === undefined) {
    return undefined;
  }
  return String(currentSessionId.value);
});

const onConversationActiveChange = (key) => {
  switchSession(Number(key));
};

const conversationMenu = (conversation) => {
  return {
    items: [{ key: "delete", label: "删除" }],
    onClick: ({ key, domEvent }) => {
      if (key === "delete") {
        deleteSession(Number(conversation.key), domEvent);
      }
    },
  };
};

const onPromptsItemClick = (info) => {
  const key = info?.data?.key;
  const template = (patentTemplates.value || []).find(
    (t) => String(t.id) === String(key),
  );
  if (template) {
    sendTemplate(template);
    return;
  }
  const desc = info?.data?.description;
  if (typeof desc === "string" && desc.trim()) {
    onSenderSubmit(desc.trim());
  }
};

const onSenderSubmit = (nextContent) => {
  if (typeof nextContent === "string") {
    inputMessage.value = nextContent;
  }
  sendMessage();
};

const onSenderChange = (value) => {
  inputMessage.value = value || "";
};

const isAttachmentsReady = computed(() => {
  if (uploadedFiles.value.length === 0) return true;
  return uploadedFiles.value.every((file) => file.parsed && !file.error);
});

const isAttachmentsParsing = computed(() => {
  return uploadedFiles.value.some((file) => !file.parsed && !file.error);
});

const hasSendableContent = computed(() => {
  const hasText = !!inputMessage.value.trim();
  const hasAttachments = uploadedFiles.value.length > 0;
  return hasText || (hasAttachments && isAttachmentsReady.value);
});

const isSendDisabled = computed(() => {
  return (
    isLoading.value || !hasSendableContent.value || !isAttachmentsReady.value
  );
});

const renderSenderActions = (_ori, { components }) => {
  if (isLoading.value) return h(components.LoadingButton);
  return h(components.SendButton, { disabled: isSendDisabled.value });
};

const sendMessage = async () => {
  if (isLoading.value) return;

  if (!isAttachmentsReady.value) {
    ElMessage.warning(
      isAttachmentsParsing.value
        ? "文件解析中，请等待解析完成后再发送"
        : "存在解析失败的文件，请移除后再发送",
    );
    return;
  }

  const trimmed = inputMessage.value.trim();
  const hasText = !!trimmed;
  const hasAttachments = uploadedFiles.value.length > 0;

  if (!hasText && !hasAttachments) return;

  const defaultAuditMessage =
    "请根据我刚刚上传的专利文档，先给出整体概览、关键创新点和主要风险点的审核意见。";
  const defaultIPCMessage =
    "请根据我上传的专利文档内容，帮我进行 IPC 分类，并说明每个分类号的含义和选择理由。";
  const selectedTemplateId =
    currentTemplateId.value != null ? Number(currentTemplateId.value) : null;
  const isIPCSelected = Number(selectedTemplateId) === 5;
  const isStrictAuditSelected =
    Number(selectedTemplateId) === 1 || Number(selectedTemplateId) === 3;
  const isPureAttachment = !hasText && hasAttachments;

  const messageContent = hasText
    ? trimmed
    : isIPCSelected
      ? defaultIPCMessage
      : isStrictAuditSelected
        ? ""
        : defaultAuditMessage;
  const displayContent =
    isPureAttachment && isStrictAuditSelected
      ? "（已上传文档，按模板审核）"
      : messageContent;
  const attachments = hasAttachments ? [...uploadedFiles.value] : null;

  messages.value.push({
    role: "user",
    content: displayContent,
    fullContent: messageContent,
    timestamp: new Date(),
    attachments: attachments,
    templateId:
      currentTemplateId.value != null ? Number(currentTemplateId.value) : null,
  });

  inputMessage.value = "";
  uploadedFiles.value = [];
  attachmentsOpen.value = false;
  attachmentItems.value = [];

  await generateAIResponse(
    messageContent,
    attachments,
    currentTemplateId.value != null
      ? { templateId: Number(currentTemplateId.value) }
      : isPureAttachment
        ? { forceAudit: true }
        : {},
  );

  currentTemplateId.value = null;
};

const generateAIResponse = async (message, attachments, options = {}) => {
  isLoading.value = true;
  currentResponse.value = "";
  const { templateId = null, forceAudit = false } = options;

  try {
    const isIPC = Number(templateId) === 5;

    const isGeneralCaseAudit = Number(templateId) === 1;
    const isProjectCaseAudit = Number(templateId) === 3;
    const systemPrompt =
      isGeneralCaseAudit || isProjectCaseAudit
        ? ""
        : isIPC
          ? `${buildIPCSystemPrompt()}

补充约束：
- 只做 IPC 分类相关输出，不要输出新颖性/创造性/实用性、撰写建议、风险提示、授权可能性等“专利审核/可专利性”内容。
- 不要引用专利法条或给出法律结论。`
          : forceAudit || (attachments && attachments.length > 0)
            ? buildAuditSystemPrompt()
            : buildPatentSystemPrompt();

    // 构建当前轮用户消息（包含本次上传的文档内容）
    let userMessage = message;
    if (attachments && attachments.length > 0) {
      // 直接附加文档内容，不添加前缀说明
      attachments.forEach((file) => {
        userMessage += `\n文档：${file.name} (${file.type})\n`;
        const parsedContent = file.parsedContent || file.parsed_content;
        if (isIPC) {
          const maxLen = 6000;
          let firstPageText = parsedContent && parsedContent.first_page_content;
          if (!firstPageText && parsedContent && parsedContent.raw_content) {
            const raw = String(parsedContent.raw_content);
            const start = raw.indexOf("[第1页]");
            if (start >= 0) {
              const afterStart = raw.slice(start);
              const nextMatch = afterStart.match(/\[第\s*2\s*页\]/);
              if (nextMatch && typeof nextMatch.index === "number") {
                firstPageText = afterStart.slice(0, nextMatch.index);
              } else {
                firstPageText = afterStart;
              }
              firstPageText = firstPageText.replace(/^\[第\s*1\s*页\]\s*/g, "");
            } else {
              firstPageText = raw;
            }
          }

          if (typeof firstPageText === "string" && firstPageText.trim()) {
            const sliced =
              firstPageText.length > maxLen
                ? firstPageText.slice(0, maxLen) + "..."
                : firstPageText;
            userMessage += `文档第一页内容：\n${sliced}\n`;
          }
        } else {
          const structured = parsedContent && parsedContent.structured;
          if (structured) {
            if (structured.title) {
              userMessage += `标题：${structured.title}\n`;
            }
            if (structured.abstract) {
              userMessage += `摘要：${structured.abstract}\n`;
            }
            if (structured.claims && structured.claims.length > 0) {
              userMessage += "部分权利要求：\n";
              structured.claims.slice(0, 3).forEach((claim) => {
                userMessage += `${claim.number}. ${claim.content}\n`;
              });
            }
            if (structured.description) {
              const desc =
                structured.description.length > 40960
                  ? structured.description.slice(0, 40960) + "..."
                  : structured.description;
              userMessage += `说明书节选：${desc}\n`;
            }
          } else if (parsedContent && parsedContent.raw_content) {
            const raw =
              parsedContent.raw_content.length > 40960
                ? parsedContent.raw_content.slice(0, 40960) + "..."
                : parsedContent.raw_content;
            userMessage += `文档内容节选：${raw}\n`;
          }
        }
      });
    }

    const isStrictTemplate =
      Number(templateId) === 1 || Number(templateId) === 3;
    const contextMessages =
      isIPC || isStrictTemplate
        ? []
        : (() => {
            const HISTORY_ROUNDS = 5;
            const conversationMessages = messages.value.filter(
              (m) => m.role === "user" || m.role === "assistant",
            );
            const previousMessages = conversationMessages.slice(0, -1);
            const limitedPrevious = previousMessages.slice(-HISTORY_ROUNDS * 2);
            return limitedPrevious.map((m) => {
              const original =
                typeof m.fullContent === "string"
                  ? m.fullContent
                  : typeof m.content === "string"
                    ? m.content
                    : "";
              if (m.role === "assistant") {
                const parts = splitThinking(original);
                return {
                  role: m.role,
                  content: parts.answer || original,
                };
              }
              return {
                role: m.role,
                content: original,
              };
            });
          })();

    const apiUrl = "/api/ai/chat";
    const headers = {
      "Content-Type": "application/json",
      Accept: "text/event-stream, application/json;q=0.9, */*;q=0.8",
      "Cache-Control": "no-cache",
    };
    const token = localStorage.getItem("token");
    if (token) {
      headers.Authorization = `Bearer ${token}`;
    }

    console.debug("[ai-chat] start", {
      templateId,
      attachments: Array.isArray(attachments) ? attachments.length : 0,
      stream: true,
    });
    const body = {
      messages: isStrictTemplate
        ? [...contextMessages, { role: "user", content: userMessage }]
        : [
            { role: "system", content: systemPrompt },
            ...contextMessages,
            { role: "user", content: userMessage },
          ],
      stream: true,
      model: "qwen3:8b",
      passthrough: false,
    };
    if (isStrictTemplate) {
      body.template_id = Number(templateId);
    }
    if (currentBackendSessionId.value) {
      body.session_id = currentBackendSessionId.value;
    }

    const controller = new AbortController();
    currentController.value = controller;
    const response = await fetch(apiUrl, {
      method: "POST",
      headers,
      body: JSON.stringify(body),
      signal: controller.signal,
    });

    console.debug("[ai-chat] response", {
      status: response.status,
      contentType: response.headers.get("content-type"),
    });
    if (!response.ok) {
      throw new Error(`AI 服务响应失败: ${response.status}`);
    }

    const contentType = response.headers.get("content-type");
    const shouldStream =
      !!response.body &&
      (body.stream ||
        (contentType && contentType.includes("text/event-stream")));
    if (shouldStream) {
      const reader = response.body.getReader();
      currentReader.value = reader;
      const decoder = new TextDecoder();
      let buffer = "";
      let eventDataLines = [];
      let streamedAny = false;

      currentThinking.value = "";
      currentAnswer.value = "";
      const handleStreamEvent = (data) => {
        if (!data) return;
        if (data === "[DONE]") return;
        try {
          const parsed = JSON.parse(data);
          if (parsed && typeof parsed.response === "string") {
            currentResponse.value = parsed.response;
            streamedAny = true;
            return;
          }
          const delta = parsed.choices?.[0]?.delta || {};
          let changed = false;
          const shouldReplace = parsed?.iprs?.replace === true;
          if (shouldReplace && delta.content) {
            const piece = String(delta.content);
            currentThinking.value = "";
            currentAnswer.value = piece;
            currentResponse.value = piece;
            changed = true;
          } else {
            if (delta.thinking) {
              const piece = String(delta.thinking);
              if (!currentResponse.value.includes("思考过程：")) {
                currentResponse.value += "思考过程：\n";
              }
              currentThinking.value += piece;
              currentResponse.value += piece;
              changed = true;
            }
            if (delta.content) {
              const piece = String(delta.content);
              if (
                currentResponse.value.includes("思考过程：") &&
                !currentResponse.value.includes("最终回答：")
              ) {
                currentResponse.value += "\n\n最终回答：\n";
              }
              currentAnswer.value += piece;
              currentResponse.value += piece;
              changed = true;
            }
          }
          if (changed) {
            streamedAny = true;
            nextTick(() => {
              scrollToBottom();
            });
          }
        } catch (e) {
          console.error("解析响应数据失败:", e, "原始数据:", data);
        }
      };

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });

        while (true) {
          const newlineIndex = buffer.indexOf("\n");
          if (newlineIndex === -1) break;

          let line = buffer.slice(0, newlineIndex);
          buffer = buffer.slice(newlineIndex + 1);
          if (line.endsWith("\r")) line = line.slice(0, -1);

          if (line.startsWith("data:")) {
            eventDataLines.push(line.slice(5).trimStart());
            continue;
          }

          if (
            line.startsWith(":") ||
            line.startsWith("event:") ||
            line.startsWith("id:") ||
            line.startsWith("retry:")
          ) {
            continue;
          }

          if (line !== "") {
            eventDataLines.push(line);
            continue;
          }

          const data = eventDataLines.join("\n").trim();
          eventDataLines = [];
          handleStreamEvent(data);
        }
      }
      if (eventDataLines.length > 0) {
        handleStreamEvent(eventDataLines.join("\n").trim());
        eventDataLines = [];
      }
      if (!streamedAny && buffer.trim()) {
        handleStreamEvent(buffer.trim());
        buffer = "";
      }
    } else {
      const data = await response.json();
      currentResponse.value = data.response || "抱歉，没有收到有效的响应。";
    }

    const wrappedContent = ensureThinkingStructure(currentResponse.value, {
      fromAudit: !isIPC && attachments && attachments.length > 0,
    });

    messages.value.push({
      role: "assistant",
      content: wrappedContent,
      timestamp: new Date(),
    });

    // 滚动到底部
    nextTick(() => {
      scrollToBottom();
    });

    await refreshSessionsFromBackend();
  } catch (error) {
    console.error("生成 AI 响应失败:", error);
    if (error && error.name === "AbortError") {
      // 用户主动停止：将当前累积内容作为部分回答输出
      const partial = ensureThinkingStructure(currentResponse.value || "", {
        fromAudit: false,
      });
      if ((currentResponse.value || "").trim().length > 0) {
        messages.value.push({
          role: "assistant",
          content: partial,
          timestamp: new Date(),
        });
      }
    } else {
      ElMessage.error("AI 响应失败，请稍后重试");
      messages.value.push({
        role: "assistant",
        content: "抱歉，我暂时无法回答您的问题。请稍后重试或联系技术支持。",
        timestamp: new Date(),
      });
    }
  } finally {
    isLoading.value = false;
    currentResponse.value = "";
    currentThinking.value = "";
    currentAnswer.value = "";
    currentReader.value = null;
    currentController.value = null;
  }
};

const generateSessionTitle = (messages) => {
  if (messages.length === 0) return "新对话";

  const userMessage = messages.find((msg) => msg.role === "user");
  if (userMessage) {
    // 如果有附件，显示"已解析文档"
    const attachments = userMessage.attachments;
    if (attachments && attachments.length > 0) {
      return "已解析文档";
    }

    const content = userMessage.content || "";
    const fullContent = userMessage.fullContent || "";

    // 检查是否是上传文档后的审核会话
    // 特征：content 很短或为空，或包含"已上传文档"标记
    const isUploadedDoc =
      !content ||
      content === "" ||
      content === "（已上传文档，按模板审核）" ||
      content.length < 5;

    // 检查 fullContent 是否包含文档内容片段（说明是从后端加载的已解析文档会话）
    const hasDocContent =
      fullContent &&
      (fullContent.includes("文档：") ||
        fullContent.includes("标题：") ||
        fullContent.includes("摘要：") ||
        fullContent.includes("权利要求"));

    if (isUploadedDoc || hasDocContent) {
      return "已解析文档";
    }

    return content.length > 20 ? content.substring(0, 20) + "..." : content;
  }

  return "新对话";
};

const saveCurrentSession = () => {
  if (messages.value.length === 0) return;

  const now = Date.now();

  if (!currentBackendSessionId.value) {
    return;
  }

  const sessionId = currentBackendSessionId.value;
  const sessionIndex = chatSessions.value.findIndex((s) => s.id === sessionId);
  if (sessionIndex !== -1) {
    chatSessions.value[sessionIndex] = {
      ...chatSessions.value[sessionIndex],
      messages: [...messages.value],
      updatedAt: now,
      title: generateSessionTitle(messages.value),
      messageCount: messages.value.length,
    };
  }
};

const loadSessions = async () => {
  try {
    const sessions = await api.get("/ai/sessions");
    const loadedSessions = [];

    for (const s of sessions) {
      const lastTime = s.last_message_at || s.updated_at || s.created_at;
      let messages = [];

      // 尝试加载消息
      try {
        const data = await api.get(`/ai/sessions/${s.id}`);
        messages = (data.messages || []).map((item) => ({
          role: item.role,
          content: item.content || "",
          fullContent: item.content || "",
          timestamp: item.created_at ? new Date(item.created_at) : new Date(),
        }));
      } catch (e) {
        console.error(`加载会话 ${s.id} 消息失败:`, e);
      }

      // 根据消息内容生成合适的标题
      const generatedTitle = generateSessionTitle(messages);

      loadedSessions.push({
        id: s.id,
        title: generatedTitle,
        messages: messages,
        createdAt: s.created_at ? new Date(s.created_at).getTime() : null,
        updatedAt: lastTime ? new Date(lastTime).getTime() : null,
        messageCount:
          typeof s.message_count === "number"
            ? s.message_count
            : messages.length,
      });
    }

    chatSessions.value = loadedSessions;
  } catch (e) {
    console.error("加载聊天记录失败:", e);
    chatSessions.value = [];
  }
};

const fetchSessionMessages = async (sessionId) => {
  try {
    const data = await api.get(`/ai/sessions/${sessionId}`);
    const list = (data.messages || []).map((item) => ({
      role: item.role,
      content: item.content || "",
      fullContent: item.content || "",
      timestamp: item.created_at ? new Date(item.created_at) : new Date(),
    }));
    const sessionIndex = chatSessions.value.findIndex(
      (s) => s.id === sessionId,
    );
    if (sessionIndex !== -1) {
      // 根据消息内容重新生成标题
      const generatedTitle = generateSessionTitle(list);
      chatSessions.value[sessionIndex] = {
        ...chatSessions.value[sessionIndex],
        messages: list,
        messageCount: list.length,
        title: generatedTitle,
      };
    }
    return list;
  } catch (e) {
    console.error("加载会话消息失败:", e);
    ElMessage.error("加载会话消息失败，请稍后重试");
    return [];
  }
};

const switchSession = async (sessionId) => {
  if (messages.value.length > 0) {
    saveCurrentSession();
  }

  const session = chatSessions.value.find((s) => s.id === sessionId);
  if (!session) return;

  currentSessionId.value = sessionId;
  currentBackendSessionId.value = sessionId;
  localStorage.setItem("currentSessionId", String(sessionId));

  if (!session.messages || session.messages.length === 0) {
    const list = await fetchSessionMessages(sessionId);
    messages.value = [...list];
  } else {
    messages.value = [...session.messages];
  }
};

const createNewSession = () => {
  if (messages.value.length > 0) {
    saveCurrentSession();
  }

  currentSessionId.value = null;
  currentBackendSessionId.value = null;
  messages.value = [];
  localStorage.removeItem("currentSessionId");
};

const createNewSessionAndHideSidebar = () => {
  createNewSession();
  showSidebar.value = false;
};

const deleteSession = async (sessionId, event) => {
  event.stopPropagation();

  try {
    await api.delete(`/ai/sessions/${sessionId}`);

    const index = chatSessions.value.findIndex((s) => s.id === sessionId);
    if (index !== -1) {
      chatSessions.value.splice(index, 1);
    }

    if (currentSessionId.value === sessionId) {
      createNewSession();
    }

    if (chatSessions.value.length === 0) {
      localStorage.removeItem("currentSessionId");
    }
  } catch (error) {
    console.error("删除会话失败:", error);
    ElMessage.error("删除会话失败，请稍后重试");
  }
};

const formatTime = (timestamp) => {
  const date = new Date(timestamp);
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));

  if (days === 0) {
    return "今天";
  } else if (days === 1) {
    return "昨天";
  } else if (days < 7) {
    return `${days}天前`;
  } else {
    return date.toLocaleDateString();
  }
};

const scrollToBottom = () => {
  nextTick(() => {
    const instance = bubbleListRef.value;
    const nativeRef = instance?.nativeElement;
    const el =
      instance?.$el ||
      nativeRef?.$el ||
      nativeRef?.value ||
      nativeRef ||
      instance?.value ||
      null;

    if (!el) return;

    if (typeof instance?.scrollTo === "function") {
      instance.scrollTo({ offset: el.scrollHeight, behavior: "auto" });
      return;
    }

    el.scrollTop = el.scrollHeight;
  });
};

const splitThinking = (content, options = { allowPartial: false }) => {
  if (!content || typeof content !== "string") {
    return {
      thinking: null,
      answer: content || "",
    };
  }

  const thinkingLabels = [
    "思考过程（简要分析）：",
    "思考过程（简要分析）:",
    "思考过程：",
    "思考过程:",
  ];
  const answerLabels = ["最终回答：", "最终回答:"];

  let thinkingLabel = "";
  let thinkingIndex = -1;
  for (const label of thinkingLabels) {
    const idx = content.indexOf(label);
    if (idx !== -1) {
      thinkingLabel = label;
      thinkingIndex = idx;
      break;
    }
  }

  if (thinkingIndex === -1) {
    return {
      thinking: null,
      answer: content,
    };
  }

  let answerLabel = "";
  let answerIndex = -1;
  for (const label of answerLabels) {
    const idx = content.indexOf(label, thinkingIndex + thinkingLabel.length);
    if (idx !== -1) {
      answerLabel = label;
      answerIndex = idx;
      break;
    }
  }

  if (answerIndex === -1) {
    if (!options.allowPartial) {
      return {
        thinking: null,
        answer: content,
      };
    }

    const thinkingOnlyBody = content
      .slice(thinkingIndex + thinkingLabel.length)
      .trim();
    if (!thinkingOnlyBody) {
      return {
        thinking: null,
        answer: content,
      };
    }

    return {
      thinking: `思考过程：\n${thinkingOnlyBody}`,
      answer: "",
    };
  }

  const thinkingBody = content
    .slice(thinkingIndex + thinkingLabel.length, answerIndex)
    .trim();
  const answerBody = content.slice(answerIndex + answerLabel.length).trim();

  if (!thinkingBody && !answerBody) {
    return {
      thinking: null,
      answer: content,
    };
  }

  return {
    thinking: thinkingBody ? `思考过程：\n${thinkingBody}` : null,
    answer: answerBody || "",
  };
};

const toggleThinking = (index) => {
  const current = !!thinkingExpanded.value[index];
  thinkingExpanded.value = {
    ...thinkingExpanded.value,
    [index]: !current,
  };
};

const isThinkingVisible = (index) => {
  return !!thinkingExpanded.value[index];
};

const toggleStreamingThinking = () => {
  streamingThinkingExpanded.value = !streamingThinkingExpanded.value;
};

const openFilePreview = (file) => {
  const parsed = file.parsedContent || file.parsed_content || null;
  if (!parsed) return;

  let preview = "";

  const structured = parsed.structured;
  if (structured) {
    if (structured.abstract) {
      preview += `【摘要】\n${structured.abstract}\n\n`;
    }
    if (structured.claims && structured.claims.length > 0) {
      const claimsText = structured.claims
        .slice(0, 3)
        .map(
          (claim) =>
            `${claim.number ? claim.number + ". " : ""}${claim.content || ""}`,
        )
        .join("\n");
      preview += `【部分权利要求】\n${claimsText}\n\n`;
    }
    if (structured.description) {
      const desc =
        structured.description.length > 800
          ? structured.description.slice(0, 800) + "..."
          : structured.description;
      preview += `【说明书节选】\n${desc}\n`;
    }
  }

  if (!preview && parsed.raw_content) {
    const raw =
      parsed.raw_content.length > 800
        ? parsed.raw_content.slice(0, 800) + "..."
        : parsed.raw_content;
    preview = raw;
  }

  if (!preview) {
    preview = "暂时没有可预览的解析内容。";
  }

  previewTitle.value = file.name;
  previewContent.value = preview;
  previewDialogVisible.value = true;
};

const copyToClipboard = async (text) => {
  const content = typeof text === "string" ? text : "";
  if (!content) {
    throw new Error("empty");
  }

  if (window.isSecureContext && navigator?.clipboard?.writeText) {
    await navigator.clipboard.writeText(content);
    return;
  }

  const textarea = document.createElement("textarea");
  textarea.value = content;
  textarea.setAttribute("readonly", "true");
  textarea.style.position = "fixed";
  textarea.style.left = "-9999px";
  textarea.style.top = "0";
  textarea.style.opacity = "0";
  document.body.appendChild(textarea);
  textarea.focus();
  textarea.select();
  textarea.setSelectionRange(0, textarea.value.length);
  const ok = document.execCommand("copy");
  document.body.removeChild(textarea);

  if (!ok) {
    throw new Error("copy_failed");
  }
};

const copyMessage = async (content) => {
  const original = typeof content === "string" ? content : "";
  const parts = splitThinking(original);
  const text = (parts.answer || "").trim() ? parts.answer : original;

  if (!text || !String(text).trim()) {
    ElMessage.warning("没有可复制的内容");
    return;
  }

  try {
    await copyToClipboard(text);
    ElMessage.success("已复制到剪贴板");
  } catch {
    ElMessage.error("复制失败，请手动选择复制");
  }
};

const regenerateResponse = async (index) => {
  const prev = messages.value[index - 1];
  const userMessage = prev?.fullContent || prev?.content;
  const attachments = prev?.attachments;
  const templateId = prev?.templateId;

  if (typeof userMessage === "string" && userMessage) {
    messages.value.splice(index);
    await generateAIResponse(userMessage, attachments, { templateId });
  }
};

const clearChat = () => {
  createNewSession();
  uploadedFiles.value = [];
  inputMessage.value = "";
  currentResponse.value = "";
  currentTemplateId.value = null;
  attachmentsOpen.value = false;
  attachmentItems.value = [];
};

// 文件上传相关
const beforeUpload = (file) => {
  const isValidType = [
    "application/msword",
    "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
    "application/pdf",
  ].includes(file.type);
  const isLt20M = file.size / 1024 / 1024 < 20;

  if (!isValidType) {
    ElMessage.error("只能上传 .doc/.docx/.pdf 格式的文件!");
    return false;
  }
  if (!isLt20M) {
    ElMessage.error("文件大小不能超过 20MB!");
    return false;
  }

  return true;
};

const refreshSessionsFromBackend = async () => {
  await loadSessions();

  if (!currentBackendSessionId.value && chatSessions.value.length > 0) {
    const first = chatSessions.value[0];
    currentSessionId.value = first.id;
    currentBackendSessionId.value = first.id;
    localStorage.setItem("currentSessionId", String(first.id));
    const index = chatSessions.value.findIndex((s) => s.id === first.id);
    if (index !== -1) {
      chatSessions.value[index] = {
        ...chatSessions.value[index],
        messages: [...messages.value],
        messageCount: messages.value.length,
      };
    }
  } else if (currentBackendSessionId.value) {
    const index = chatSessions.value.findIndex(
      (s) => s.id === currentBackendSessionId.value,
    );
    if (index !== -1) {
      chatSessions.value[index] = {
        ...chatSessions.value[index],
        messages: [...messages.value],
        messageCount: messages.value.length,
        updatedAt: Date.now(),
      };
    }
  }
};

onMounted(async () => {
  inputMessage.value = "";
  currentTemplateId.value = null;

  setTimeout(() => {
    if (!inputMessage.value) {
      inputMessage.value = "";
    }
  }, 300);

  await loadSessions();

  try {
    const stored = localStorage.getItem(UPLOADED_FILES_STORAGE_KEY);
    if (stored) {
      const parsed = JSON.parse(stored);
      if (Array.isArray(parsed)) {
        uploadedFiles.value = parsed.map((item) => ({
          id: item.id,
          name: item.name,
          type: item.type,
          parsed: !!item.parsed,
          parsedContent: item.parsedContent || item.parsed_content || null,
          error: !!item.error,
          parsingThinkingSteps: item.parsingThinkingSteps || [],
        }));
      }
    }
  } catch (e) {
    console.error("恢复上传文件状态失败:", e);
  }

  attachmentItems.value = uploadedFiles.value.map((file) => ({
    uid: String(file.id),
    name: file.name,
    status: file.error ? "error" : "done",
    description: file.error ? "解析失败" : file.parsed ? "已解析" : "解析中...",
    docId: file.id,
  }));

  // 注册点击事件监听器用于停止加载
  document.addEventListener("click", stopLoadingClickHandler, true);
});

// 监听消息变化，自动保存会话
watch(
  () => messages.value.length,
  () => {
    if (messages.value.length > 0) {
      saveCurrentSession();
    }
  },
  { deep: true },
);

// 页面卸载时保存当前会话
onUnmounted(() => {
  if (messages.value.length > 0) {
    saveCurrentSession();
  }
  document.removeEventListener("click", stopLoadingClickHandler, true);
});

const beforeAntdUpload = (file) => {
  return beforeUpload(file);
};

const stopLoading = async () => {
  try {
    if (
      currentReader.value &&
      typeof currentReader.value.cancel === "function"
    ) {
      await currentReader.value.cancel();
    }
    if (currentController.value) {
      currentController.value.abort();
    }
  } catch (e) {
    console.warn("停止流失败:", e);
  } finally {
    isLoading.value = false;
  }
};

const stopLoadingClickHandler = (e) => {
  const target = e.target;
  if (!target) return;
  const el =
    typeof target.closest === "function"
      ? target.closest(".ant-sender-actions-btn-loading-icon")
      : null;
  if (el) {
    stopLoading();
  }
};

const handleAttachmentsChange = (info) => {
  const list = Array.isArray(info?.fileList) ? info.fileList : [];
  attachmentItems.value = list.map((item) => {
    const matched = uploadedFiles.value.find(
      (f) =>
        String(f.id) === String(item.docId) ||
        String(f.id) === String(item.response?.id) ||
        String(f.uid) === String(item.uid),
    );
    if (!matched) return item;
    return {
      ...item,
      docId: matched.id,
      description: matched.error
        ? "解析失败"
        : matched.parsed
          ? "已解析"
          : "解析中...",
      status: matched.error ? "error" : "done",
    };
  });
};

const handleAttachmentRemove = (file) => {
  const uid = file?.uid;
  if (!uid) return true;
  attachmentItems.value = attachmentItems.value.filter(
    (f) => String(f.uid) !== String(uid),
  );
  const index = uploadedFiles.value.findIndex(
    (f) => String(f.id) === String(uid) || String(f.uid) === String(uid),
  );
  if (index !== -1) {
    uploadedFiles.value.splice(index, 1);
  }
  return true;
};

const handleAttachmentCustomRequest = async (options) => {
  const { file, onError, onSuccess } = options || {};
  const uid = file?.uid ? String(file.uid) : String(Date.now());
  const rawFile = file instanceof File ? file : file?.originFileObj;

  if (!rawFile || !beforeUpload(rawFile)) {
    if (onError) onError(new Error("invalid file"));
    return;
  }

  const formData = new FormData();
  formData.append("file", rawFile);
  formData.append("title", rawFile.name);

  try {
    const uploaded = await uploadDocument(formData);

    const fileItem = {
      uid,
      id: uploaded.id,
      name: uploaded.title || rawFile.name,
      type: uploaded.file_type,
      parsed: uploaded.status === "parsed" && !!uploaded.parsed_content,
      parsedContent: uploaded.parsed_content || null,
      error: false,
      parsingThinkingSteps: [
        { step: "文件上传成功，开始解析", status: "completed" },
        { step: "提取文件内容", status: "pending" },
        { step: "结构化内容分析", status: "pending" },
        { step: "解析完成", status: "pending" },
      ],
    };

    uploadedFiles.value.push(fileItem);

    attachmentItems.value = attachmentItems.value.map((item) => {
      if (String(item.uid) !== String(uid)) return item;
      return {
        ...item,
        status: "done",
        docId: uploaded.id,
        description: fileItem.parsed ? "已解析" : "解析中...",
      };
    });

    if (!fileItem.parsed) {
      try {
        const parsedResult = await parseDocument(uploaded.id);
        fileItem.parsingThinkingSteps[1].status = "completed";
        fileItem.parsingThinkingSteps[2].status = "completed";
        if (parsedResult?.status === "parsed" && parsedResult.parsed_content) {
          fileItem.parsed = true;
          fileItem.parsedContent = parsedResult.parsed_content;
          fileItem.error = false;
          fileItem.parsingThinkingSteps[3].status = "completed";
        } else {
          fileItem.error = true;
          fileItem.parsingThinkingSteps[3].status = "error";
        }
      } catch (parseError) {
        console.error("解析文档失败:", parseError);
        fileItem.error = true;
        fileItem.parsingThinkingSteps[3].status = "error";
        ElMessage.error("文档解析失败，请检查文件内容或稍后重试");
      }

      const index = uploadedFiles.value.findIndex((f) => f.id === fileItem.id);
      if (index !== -1) {
        uploadedFiles.value[index] = {
          ...uploadedFiles.value[index],
          parsed: !!fileItem.parsed,
          parsedContent: fileItem.parsedContent,
          error: !!fileItem.error,
          parsingThinkingSteps: fileItem.parsingThinkingSteps,
        };
      }

      attachmentItems.value = attachmentItems.value.map((item) => {
        if (String(item.uid) !== String(uid)) return item;
        return {
          ...item,
          status: fileItem.error ? "error" : "done",
          description: fileItem.error
            ? "解析失败"
            : fileItem.parsed
              ? "已解析"
              : "解析中...",
        };
      });
    }

    if (onSuccess) {
      onSuccess(uploaded, rawFile);
    }

    if (fileItem.parsed) {
      ElMessage.success("文件上传并解析成功");
    } else {
      ElMessage.success("文件上传成功，解析任务已启动");
    }
  } catch (error) {
    console.error("文件上传失败:", error);
    ElMessage.error("文件上传失败，请稍后重试");
    attachmentItems.value = attachmentItems.value.map((item) => {
      if (String(item.uid) !== String(uid)) return item;
      return {
        ...item,
        status: "error",
        description: "上传失败",
      };
    });
    if (onError) {
      onError(error);
    }
  }
};
</script>

